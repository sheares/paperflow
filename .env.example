# ── Remote reasoning ──────────────────────────────────────────────
# Fireworks API key for cross-doc chat reasoning on redacted tokens.
# Optional: leave FIREWORKS_API_KEY empty and paperflow runs in
# air-gapped mode (no cloud calls, local rules for reconciliation).
FIREWORKS_API_KEY=

# Which Fireworks model to use for the tokenised reconciliation call.
# docker-compose.yml sets this to 'minimax' (~5.8x cheaper than
# DeepSeek V4 Pro on the same tokenised-JSON reasoning task with
# comparable quality). Override here if you want a different model.
# Accepts an alias (minimax / deepseek / qwen / glm) or a full slug
# like 'accounts/fireworks/models/deepseek-v4-pro'. See
# paperflow/models.py for the registry.
# FIREWORKS_MODEL=minimax

# ── Local extractor (Gemma-4-31B-IT on the MI300X) ────────────────
# vLLM endpoint for vision extraction. If unreachable, paperflow
# still runs on text-only files (TXT/MD/XLSX) and cached samples;
# PDF/image uploads need the MI300X live. See scripts/droplet.sh for
# the sleep/wake/tunnel lifecycle we use during the hackathon.
VLLM_URL=http://localhost:8000/v1
VLLM_MODEL=google/gemma-4-31b-it
